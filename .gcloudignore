# This file specifies files that are *not* to be uploaded to Google Cloud.
# It is recommended to keep this synced with your .gitignore but optimized for cloud uploads.

# Version Control
.git/

# Python
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.venv/
venv/
.coverage
**/.coverage

# Node.js / Frontend
**/node_modules/
**/dist/
**/.angular/
**/npm-debug.log

# Terraform
terraform/
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
**/*.tfvars.json
**/.terraform.lock.hcl
*.tfplan*

# Editor and IDE
.vscode/
.idea/
.DS_Store

# Environment Variables
**/.env

# Project specific
assets/
conductor/
.gemini/
